---
import { env } from "cloudflare:workers";
import Layout from "../../components/Layout.astro";
import { getBriefingById, parsePrimitives, parseSummary } from "../../lib/db";

const { id } = Astro.params;
const briefing = env.DB && id ? await getBriefingById(env.DB, id) : null;

if (!briefing) {
	return new Response(null, { status: 404, statusText: "Briefing not found" });
}

const summary = parseSummary(briefing.row.summary_json);

const itemUrlByTitle = new Map<string, string>();
for (const item of briefing.items) {
	itemUrlByTitle.set(item.title.trim(), item.url);
}
function urlForTitle(title: string): string | null {
	return itemUrlByTitle.get(title.trim()) ?? null;
}
function sourceLabel(source: string): string {
	switch (source) {
		case "hn": return "HN";
		case "reddit": return "Reddit";
		case "answer-overflow": return "Discord";
		default: return source;
	}
}

const dateLabel = new Date(briefing.row.run_started_at).toLocaleDateString(
	"en-US",
	{
		weekday: "long",
		month: "long",
		day: "numeric",
		year: "numeric",
	},
);
---

<Layout title={`${dateLabel} — FlareCraft`}>
	<div class="prose-page">
		<header class="briefing-hero">
			<span class="eyebrow">Briefing &middot; {dateLabel}</span>
			<h1 class="serif">What developers <i>shipped</i></h1>
			<p class="lede">
				<strong>{briefing.row.kept_count}</strong> items kept &middot; {briefing.row.classified_count} classified &middot; {briefing.row.source_count} sourced &middot; {briefing.row.deduped_count} deduplicated.
			</p>
		</header>

		{summary && (summary.positives.length > 0 || summary.negatives.length > 0 || summary.questions.length > 0) && (
			<section class="cut">
				<span class="eyebrow">The cut &middot; the day's read</span>
				<div class="cut-grid">
					{summary.positives.length > 0 && (
						<div class="cut-col cut-col--pos">
							<h3 class="serif">What's working</h3>
							<ol>
								{summary.positives.map((p) => {
									const url = urlFor(p);
									return (
										<li>
											{url ? (
												<a href={url} target="_blank" rel="noopener" class="cut-link">
													<strong>{p.title}.</strong>
												</a>
											) : (
												<strong>{p.title}.</strong>
											)}
											{" "}{p.line}
										</li>
									);
								})}
							</ol>
						</div>
					)}
					{summary.negatives.length > 0 && (
						<div class="cut-col cut-col--neg">
							<h3 class="serif">What's friction</h3>
							<ol>
								{summary.negatives.map((p) => {
									const url = urlFor(p);
									return (
										<li>
											{url ? (
												<a href={url} target="_blank" rel="noopener" class="cut-link">
													<strong>{p.title}.</strong>
												</a>
											) : (
												<strong>{p.title}.</strong>
											)}
											{" "}{p.line}
										</li>
									);
								})}
							</ol>
						</div>
					)}
					{summary.questions.length > 0 && (
						<div class="cut-col cut-col--qa">
							<h3 class="serif">What's being asked</h3>
							<ol>
								{summary.questions.map((p) => {
									const url = urlFor(p);
									return (
										<li>
											{url ? (
												<a href={url} target="_blank" rel="noopener" class="cut-link">
													<strong>{p.title}.</strong>
												</a>
											) : (
												<strong>{p.title}.</strong>
											)}
											{" "}{p.line}
										</li>
									);
								})}
							</ol>
						</div>
					)}
				</div>
			</section>
		)}

		<section class="briefing">
			{briefing.items.map((item, i) => {
				const primitives = parsePrimitives(item.primitives);
				return (
					<article class={`item item--score-${item.score}`}>
						<aside class="item-num serif">{String(i + 1).padStart(2, "0")}</aside>
						<div class="item-body">
							<div class="item-meta">
								<span class="eyebrow">
									{"★".repeat(item.score)}{"☆".repeat(5 - item.score)}
									{" · "}
									{item.angle}
									{item.resolved !== null && (
										<>{" · "}{item.resolved === 1 ? "resolved" : "open"}</>
									)}
									{" · "}
									via {sourceLabel(item.source)}
								</span>
							</div>
							<h2 class="serif">
								<a href={item.url} target="_blank" rel="noopener">{item.title}</a>
							</h2>
							<p class="item-summary">{item.one_liner}</p>
							{primitives.length > 0 && (
								<p class="item-primitives">
									{primitives.map((p, idx) => (
										<>
											<span class="primitive">{p}</span>
											{idx < primitives.length - 1 && <span class="dot"> · </span>}
										</>
									))}
								</p>
							)}
						</div>
					</article>
				);
			})}
		</section>

		<p class="back"><a href="/archive/">← All briefings</a></p>
	</div>
</Layout>

<style>
	.briefing-hero {
		margin-bottom: 48px;
	}
	.briefing-hero h1 {
		font-size: var(--fs-h1);
		font-weight: 700;
		line-height: 1.05;
		letter-spacing: -0.025em;
		margin: 16px 0 20px;
		font-variation-settings: "SOFT" 50;
	}
	.briefing-hero h1 i {
		font-style: italic;
		color: var(--orange-deep);
	}
	.lede {
		font-size: 17px;
		color: var(--ink-2);
		margin: 0;
	}
	.lede strong {
		color: var(--ink);
		font-weight: 600;
	}
	.cut {
		margin: 0 0 48px;
		padding: 28px;
		background: var(--paper-2);
		border-left: 3px solid var(--orange-deep);
		border-radius: 0 4px 4px 0;
	}
	.cut .eyebrow { margin-bottom: 14px; }
	.cut-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 24px;
	}
	@media (max-width: 760px) {
		.cut-grid { grid-template-columns: 1fr; gap: 20px; }
	}
	.cut-col h3 {
		margin: 0 0 10px;
		font-size: 16px;
		font-weight: 600;
		font-variation-settings: "SOFT" 50;
	}
	.cut-col--pos h3::before { content: "+ "; color: var(--orange-deep); font-family: var(--font-mono); }
	.cut-col--neg h3::before { content: "− "; color: var(--ink-3); font-family: var(--font-mono); }
	.cut-col--qa h3::before { content: "? "; color: var(--ember); font-family: var(--font-mono); }
	.cut-col ol { margin: 0; padding: 0 0 0 18px; font-size: 14px; line-height: 1.55; color: var(--ink-2); }
	.cut-col li { margin-bottom: 8px; }
	.cut-col strong { color: var(--ink); font-weight: 600; }
	.cut-link { color: inherit; text-decoration: none; border-bottom: 1px solid var(--rule-2); transition: color .15s var(--ease), border-color .15s var(--ease); }
	.cut-link:hover { color: var(--orange-deep); border-bottom-color: var(--orange-deep); }

	.item {
		display: grid;
		grid-template-columns: 56px 1fr;
		gap: 24px;
		padding: 32px 0;
		border-top: 1px solid var(--rule);
	}
	.item:last-of-type {
		border-bottom: 1px solid var(--rule);
	}
	.item--score-5 {
		background: linear-gradient(
			to right,
			var(--orange-pale) 0%,
			rgba(253, 233, 210, 0) 50%
		);
		margin: 0 -16px;
		padding-left: 16px;
		padding-right: 16px;
	}
	.item--score-5 .item-num {
		color: var(--ember);
	}
	.item-num {
		font-size: 28px;
		font-weight: 600;
		color: var(--ink-3);
		font-variant-numeric: tabular-nums;
		line-height: 1;
		padding-top: 6px;
		font-variation-settings: "SOFT" 50;
	}
	.item-meta {
		margin-bottom: 10px;
	}
	.item h2 {
		margin: 0 0 12px;
		font-size: var(--fs-h3);
		font-weight: 600;
		line-height: 1.3;
		letter-spacing: -0.01em;
		font-variation-settings: "SOFT" 50;
	}
	.item h2 a {
		text-decoration: none;
	}
	.item-summary {
		margin: 0 0 14px;
		font-size: 15.5px;
		color: var(--ink-2);
		line-height: 1.55;
	}
	.item-primitives {
		margin: 0;
		font-size: 14px;
		color: var(--ember);
	}
	.item-primitives .dot {
		color: var(--ink-3);
		margin: 0 4px;
	}
	.back {
		margin-top: 56px;
		font-size: 14px;
	}
	.back a {
		color: var(--orange-deep);
		text-decoration: none;
		font-weight: 600;
	}
</style>
