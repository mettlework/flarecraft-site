---
import { env } from "cloudflare:workers";
import Layout from "../../components/Layout.astro";
import { getRecentBriefings } from "../../lib/db";

const briefings = env.DB ? await getRecentBriefings(env.DB, 30) : [];
---

<Layout
	title="Archive — FlareCraft"
	description="Past daily briefings of Cloudflare developer activity."
>
	<div class="prose-page">
		<header class="archive-hero">
			<span class="eyebrow">Archive</span>
			<h1 class="serif">Past <i>briefings</i></h1>
			<p class="lede">
				Every daily run is preserved. Click any date to see what made the cut.
			</p>
		</header>

		<section class="archive-list">
			{briefings.length === 0 && (
				<p class="empty">No completed briefings yet.</p>
			)}
			{briefings.map((b) => {
				const date = new Date(b.run_started_at).toLocaleDateString("en-US", {
					weekday: "long",
					month: "long",
					day: "numeric",
					year: "numeric",
				});
				return (
					<a class="row" href={`/briefing/${b.id}/`}>
						<div class="row-date serif">{date}</div>
						<div class="row-stats">
							<span><strong class="mono">{b.kept_count}</strong> kept</span>
							<span class="dim">/</span>
							<span class="dim mono">{b.classified_count} classified</span>
							<span class="dim">/</span>
							<span class="dim mono">{b.source_count} sourced</span>
						</div>
					</a>
				);
			})}
		</section>
	</div>
</Layout>

<style>
	.archive-hero {
		margin-bottom: 48px;
	}
	.archive-hero h1 {
		font-size: var(--fs-h1);
		font-weight: 700;
		line-height: 1.05;
		letter-spacing: -0.025em;
		margin: 16px 0 20px;
		font-variation-settings: "SOFT" 50;
	}
	.archive-hero h1 i {
		font-style: italic;
		color: var(--orange-deep);
	}
	.lede {
		font-size: 18px;
		color: var(--ink-2);
		margin: 0;
	}
	.empty {
		color: var(--ink-3);
		padding: 32px 0;
		font-style: italic;
	}
	.archive-list {
		border-top: 1px solid var(--rule);
	}
	.row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 20px 0;
		border-bottom: 1px solid var(--rule);
		text-decoration: none;
		color: var(--ink);
		gap: 24px;
		flex-wrap: wrap;
	}
	.row:hover .row-date {
		color: var(--orange-deep);
	}
	.row-date {
		font-size: 18px;
		font-weight: 600;
	}
	.row-stats {
		font-size: 13px;
		display: flex;
		gap: 8px;
		color: var(--ink-2);
	}
	.row-stats strong {
		color: var(--ink);
		font-weight: 600;
	}
	.row-stats .dim {
		color: var(--ink-3);
	}
</style>
