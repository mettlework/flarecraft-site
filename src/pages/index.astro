---
import { env } from "cloudflare:workers";
import { getLatestBriefing, parsePrimitives } from "../lib/db";
import Layout from "../components/Layout.astro";

const briefing = env.DB ? await getLatestBriefing(env.DB) : null;

// Aggregate primitives across the briefing for the hero callout
const primitiveCounts = new Map<string, number>();
for (const item of briefing?.items ?? []) {
	for (const p of parsePrimitives(item.primitives)) {
		primitiveCounts.set(p, (primitiveCounts.get(p) ?? 0) + 1);
	}
}
const topPrimitives = [...primitiveCounts.entries()]
	.sort((a, b) => b[1] - a[1])
	.slice(0, 6)
	.map(([name, count]) => ({ name, count }));

const dateLabel = briefing
	? new Date(briefing.row.run_started_at).toLocaleDateString("en-US", {
			weekday: "long",
			month: "long",
			day: "numeric",
			year: "numeric",
		})
	: new Date().toLocaleDateString("en-US", {
			weekday: "long",
			month: "long",
			day: "numeric",
			year: "numeric",
		});
---

<Layout
	title="FlareCraft — what developers are shipping on Cloudflare"
	description="A daily AI-curated briefing of what developers are building, launching, and critiquing on the Cloudflare developer platform."
>
	<header class="hero">
		<p class="eyebrow">FlareCraft &middot; {dateLabel}</p>
		<h1>What developers are shipping<br />on Cloudflare</h1>
		<p class="lede">
			A daily briefing of posts, launches, and critiques from the open web,
			classified and ranked by Workers AI. Built end-to-end on the Cloudflare
			developer platform — the system reporting on the platform.
		</p>

		{
			briefing && (
				<dl class="stats">
					<div>
						<dt>Items today</dt>
						<dd>{briefing.row.kept_count}</dd>
					</div>
					<div>
						<dt>Sources scanned</dt>
						<dd>{briefing.row.source_count}</dd>
					</div>
					<div>
						<dt>Deduped</dt>
						<dd>{briefing.row.deduped_count}</dd>
					</div>
				</dl>
			)
		}

		{
			topPrimitives.length > 0 && (
				<div class="primitive-row">
					<span class="primitive-row-label">Across:</span>
					{topPrimitives.map((p) => (
						<span class="primitive-tag">
							{p.name}
							<span class="primitive-count">{p.count}</span>
						</span>
					))}
				</div>
			)
		}
	</header>

	<section class="briefing">
		{
			!briefing && (
				<div class="empty">
					<p>
						The first briefing hasn't run yet. Once the pipeline completes its
						first cycle, this is where today's items will live.
					</p>
				</div>
			)
		}

		{
			briefing && briefing.items.length === 0 && (
				<div class="empty">
					<p>
						The pipeline ran but didn't surface anything noteworthy in the last
						window. Check back tomorrow.
					</p>
				</div>
			)
		}

		{
			briefing &&
				briefing.items.map((item, i) => {
					const primitives = parsePrimitives(item.primitives);
					return (
						<article class={`item item--score-${item.score}`}>
							<div class="item-meta">
								<span class="item-num">{String(i + 1).padStart(2, "0")}</span>
								<span class="item-score" title={`${item.score}/5`}>
									{"★".repeat(item.score)}
									{"☆".repeat(5 - item.score)}
								</span>
								<span class="item-angle">{item.angle}</span>
								<span class="item-source">via {item.source}</span>
							</div>
							<h2>
								<a href={item.url} target="_blank" rel="noopener">
									{item.title}
								</a>
							</h2>
							<p class="item-summary">{item.one_liner}</p>
							{primitives.length > 0 && (
								<ul class="item-primitives">
									{primitives.map((p) => (
										<li>{p}</li>
									))}
								</ul>
							)}
						</article>
					);
				})
		}
	</section>

	<footer class="how">
		<h3>How this is built</h3>
		<p>
			FlareCraft is two Workers in one repo. A scheduled <strong>pipeline Worker</strong> runs daily on a Cron Trigger, fetches recent posts from Hacker News, classifies each via <strong>Workers AI</strong> (Llama 3.3 70B with structured JSON output), generates embeddings (BGE base), deduplicates semantically against the corpus via <strong>Vectorize</strong>, persists to <strong>D1</strong>, archives raw JSON to <strong>R2</strong>, and emails a digest via Resend. The whole pipeline is wrapped in <strong>Cloudflare Workflows</strong> for durable execution and per-step retries. This <strong>SSR site</strong> is the second Worker — it reads from the same D1 in the request path and renders this page server-side, no rebuild needed when the pipeline updates.
		</p>
		<p class="how-meta">
			Eight Cloudflare primitives, two Workers, one product. <a href="/about/">More on the architecture →</a>
		</p>
	</footer>
</Layout>
