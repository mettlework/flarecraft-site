---
import { env } from "cloudflare:workers";
import Layout from "../components/Layout.astro";
import {
	getLatestBriefing,
	getCorpusStats,
	getTopPrimitives,
	parsePrimitives,
	parseSummary,
} from "../lib/db";

const briefing = env.DB ? await getLatestBriefing(env.DB) : null;
const summary = briefing ? parseSummary(briefing.row.summary_json) : null;

// Title→url map as a fallback for legacy summaries. v1.2+ summaries carry
// `url` directly on each entry, resolved server-side. Fallback handles
// the AI's editorial drift (it strips prefixes like "[r/CloudFlare]" and
// "Comment on:" when summarizing, breaking exact-title matches).
const itemUrlByTitle = new Map<string, string>();
for (const item of briefing?.items ?? []) {
	itemUrlByTitle.set(item.title.trim(), item.url);
}
function urlFor(entry: { title: string; url?: string }): string | null {
	if (entry.url) return entry.url; // v1.2+ — already resolved
	return itemUrlByTitle.get(entry.title.trim()) ?? null;
}
const stats = env.DB
	? await getCorpusStats(env.DB)
	: { briefingCount: 0, itemsKept: 0, sourcesScanned: 0, lastRunAt: null };
const topPrimitives = env.DB ? await getTopPrimitives(env.DB, 6) : [];

// Compute time until next 12:00 UTC cron run (= 07:00 CT during CDT).
function nextRunInfo(): { absolute: string; relative: string } {
	const now = new Date();
	const next = new Date(now);
	next.setUTCHours(12, 0, 0, 0);
	if (next.getTime() <= now.getTime()) {
		next.setUTCDate(next.getUTCDate() + 1);
	}
	const diffMs = next.getTime() - now.getTime();
	const hours = Math.floor(diffMs / (1000 * 60 * 60));
	const minutes = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
	const relative =
		hours >= 1
			? `in ${hours}h ${minutes}m`
			: `in ${minutes}m`;
	const absolute = next.toLocaleString("en-US", {
		hour: "numeric",
		minute: "2-digit",
		timeZone: "America/Chicago",
		hour12: true,
	});
	return { absolute: `${absolute} CT`, relative };
}

const nextRun = nextRunInfo();
const dateLabel = briefing
	? new Date(briefing.row.run_started_at).toLocaleDateString("en-US", {
			month: "short",
			day: "numeric",
			year: "numeric",
		})
	: new Date().toLocaleDateString("en-US", {
			month: "short",
			day: "numeric",
			year: "numeric",
		});

const lastRunRelative = (() => {
	if (!stats.lastRunAt) return "never";
	const diffMs = Date.now() - stats.lastRunAt;
	const hours = Math.floor(diffMs / (1000 * 60 * 60));
	if (hours < 1) {
		const mins = Math.max(1, Math.floor(diffMs / (1000 * 60)));
		return `${mins}m ago`;
	}
	if (hours < 48) return `${hours}h ago`;
	const days = Math.floor(hours / 24);
	return `${days}d ago`;
})();

// Display label for the source — "answer-overflow" → "Discord" because that's
// what the user is actually reading; AO is the access mechanism, not the surface.
function sourceLabel(source: string): string {
	switch (source) {
		case "hn": return "HN";
		case "reddit": return "Reddit";
		case "answer-overflow": return "Discord";
		default: return source;
	}
}
---

<Layout
	title="FlareCraft — what developers are shipping on Cloudflare"
	description="A daily AI-curated briefing of what developers are building, launching, and critiquing on the Cloudflare developer platform. Built end-to-end on the platform itself."
>
	<div class="editorial">
		<main class="editorial-main">
			<header class="hero">
				<span class="eyebrow">FlareCraft &nbsp;·&nbsp; {dateLabel}</span>
				<h1 class="serif">
					What developers are shipping<br />on <i>Cloudflare</i>
				</h1>
				<p class="lede">
					The last 24 hours from Hacker News and Reddit, plus the past week from Cloudflare's developer Discord — classified and ranked by Workers AI.
				</p>
				<div class="hero-meta">
					<p class="hero-meta-line serif italic">
						8 Cloudflare primitives <span class="hero-dot">·</span> 2 Workers <span class="hero-dot">·</span> 3 sources
					</p>
					<p class="hero-meta-line hero-meta-bottom">
						<span class="serif italic">1 daily briefing.</span>
						<a href="/about/" class="hero-cta">Architecture →</a>
					</p>
				</div>
			</header>

			{summary && (summary.positives.length > 0 || summary.negatives.length > 0 || summary.questions.length > 0) && (
				<section class="cut">
					<span class="eyebrow">The cut &middot; today's read</span>
					<div class="cut-grid">
						{summary.positives.length > 0 && (
							<div class="cut-col cut-col--pos">
								<h3 class="serif">What's working</h3>
								<ol>
									{summary.positives.map((p) => {
										const url = urlFor(p);
										return (
											<li>
												{url ? (
													<a href={url} target="_blank" rel="noopener" class="cut-link">
														<strong>{p.title}.</strong>
													</a>
												) : (
													<strong>{p.title}.</strong>
												)}
												<span> {p.line}</span>
											</li>
										);
									})}
								</ol>
							</div>
						)}
						{summary.negatives.length > 0 && (
							<div class="cut-col cut-col--neg">
								<h3 class="serif">What's friction</h3>
								<ol>
									{summary.negatives.map((p) => {
										const url = urlFor(p);
										return (
											<li>
												{url ? (
													<a href={url} target="_blank" rel="noopener" class="cut-link">
														<strong>{p.title}.</strong>
													</a>
												) : (
													<strong>{p.title}.</strong>
												)}
												<span> {p.line}</span>
											</li>
										);
									})}
								</ol>
							</div>
						)}
						{summary.questions.length > 0 && (
							<div class="cut-col cut-col--qa">
								<h3 class="serif">What's being asked</h3>
								<ol>
									{summary.questions.map((p) => {
										const url = urlFor(p);
										return (
											<li>
												{url ? (
													<a href={url} target="_blank" rel="noopener" class="cut-link">
														<strong>{p.title}.</strong>
													</a>
												) : (
													<strong>{p.title}.</strong>
												)}
												<span> {p.line}</span>
											</li>
										);
									})}
								</ol>
							</div>
						)}
					</div>
				</section>
			)}

			<section class="briefing">
				{!briefing && (
					<div class="empty">
						<p>The first briefing hasn't run yet.</p>
					</div>
				)}

				{briefing && briefing.items.length === 0 && (
					<div class="empty">
						<p>The pipeline ran but didn't surface anything noteworthy in the last window. Check back tomorrow.</p>
					</div>
				)}

				{briefing &&
					briefing.items.map((item, i) => {
						const primitives = parsePrimitives(item.primitives);
						return (
							<article class={`item item--score-${item.score}`}>
								<aside class="item-num serif">{String(i + 1).padStart(2, "0")}</aside>
								<div class="item-body">
									<div class="item-meta">
										<span class="eyebrow">
											{"★".repeat(item.score)}{"☆".repeat(5 - item.score)}
											{" · "}
											{item.angle}
											{item.resolved !== null && (
												<>{" · "}{item.resolved === 1 ? "resolved" : "open"}</>
											)}
											{" · "}
											via {sourceLabel(item.source)}
										</span>
									</div>
									<h2 class="serif">
										<a href={item.url} target="_blank" rel="noopener">
											{item.title}
										</a>
									</h2>
									<p class="item-summary">{item.one_liner}</p>
									{primitives.length > 0 && (
										<p class="item-primitives">
											{primitives.map((p, idx) => (
												<>
													<span class="primitive">{p}</span>
													{idx < primitives.length - 1 && <span class="dot"> · </span>}
												</>
											))}
										</p>
									)}
								</div>
							</article>
						);
					})}
			</section>

			{env.SUBSCRIBE_URL && (
				<aside class="subscribe-block">
					<div>
						<span class="eyebrow">Subscribe</span>
						<h3 class="serif">Get tomorrow's briefing</h3>
						<p>One email each morning. Top items developers shipped on Cloudflare in the last 24 hours, classified and ranked by Workers AI.</p>
					</div>
					<a href={env.SUBSCRIBE_URL} class="subscribe-button" target="_blank" rel="noopener">
						Subscribe →
					</a>
				</aside>
			)}

			{/* The full colophon moved above the items as a hero meta-line + CTA.
				The site-wide footer (in Layout.astro) handles the brand sign-off. */}
		</main>

		<aside class="editorial-rail" aria-label="Live system status">
			<div class="rail-section">
				<span class="pill-live">live</span>
			</div>

			<div class="rail-section">
				<span class="eyebrow">Next briefing</span>
				<div class="rail-stat-big serif">{nextRun.relative}</div>
				<div class="rail-meta">{nextRun.absolute} &middot; daily</div>
			</div>

			<div class="rail-section">
				<span class="eyebrow">Last run</span>
				<div class="rail-stat-med serif">{lastRunRelative}</div>
			</div>

			<hr class="rail-rule" />

			<div class="rail-section">
				<span class="eyebrow">The corpus</span>
				<dl class="rail-dl">
					<div>
						<dt>Briefings</dt>
						<dd class="serif">{stats.briefingCount}</dd>
					</div>
					<div>
						<dt>Items kept</dt>
						<dd class="serif">{stats.itemsKept}</dd>
					</div>
					<div>
						<dt>Sources scanned</dt>
						<dd class="serif">{stats.sourcesScanned}</dd>
					</div>
				</dl>
			</div>

			{topPrimitives.length > 0 && (
				<>
					<hr class="rail-rule" />
					<div class="rail-section">
						<span class="eyebrow">Top primitives</span>
						<ul class="rail-primitives">
							{topPrimitives.map((p) => (
								<li>
									<span class="primitive">{p.name}</span>
									<span class="rail-count mono">{p.count}</span>
								</li>
							))}
						</ul>
					</div>
				</>
			)}

			<hr class="rail-rule" />

			<div class="rail-section">
				<span class="eyebrow">About the builder</span>
				<p class="rail-text">
					<strong>Andrew Moore</strong> is a Founder, Product Executive, and Builder. <a href="https://www.linkedin.com/in/richardandrewmoore/" target="_blank" rel="noopener" class="rail-link-inline">See his work →</a>
				</p>
				<p class="rail-text" style="margin-top: 10px;">
					<a href="/about/" class="rail-link">Read the architecture →</a>
				</p>
			</div>
		</aside>
	</div>
</Layout>

<style>
	.hero {
		margin-bottom: 56px;
	}
	.hero h1 {
		font-size: var(--fs-h1);
		font-weight: 700;
		line-height: 1.05;
		letter-spacing: -0.025em;
		margin: 16px 0 20px;
		font-variation-settings: "SOFT" 50;
	}
	.hero h1 i {
		font-style: italic;
		color: var(--orange-deep);
	}
	.lede {
		font-size: 18px;
		color: var(--ink-2);
		max-width: 580px;
		margin: 0 0 16px;
	}
	.hero-meta {
		margin: 0;
	}
	.hero-meta-line {
		margin: 0;
		font-size: 16px;
		color: var(--ink-3);
		font-variation-settings: "SOFT" 50;
		line-height: 1.4;
	}
	.hero-meta-bottom {
		margin-top: 4px;
		display: flex;
		align-items: baseline;
		gap: 16px;
		flex-wrap: wrap;
	}
	.hero-dot {
		color: var(--rule-2);
		margin: 0 4px;
		font-style: normal;
	}
	.hero-cta {
		color: var(--orange-deep);
		text-decoration: none;
		font-weight: 600;
		font-family: var(--font-body);
		font-size: 15px;
		font-style: normal;
		white-space: nowrap;
	}
	.hero-cta:hover {
		text-decoration: underline;
		text-underline-offset: 4px;
	}

	/* The Cut — editorial summary block above the items list */
	.cut {
		margin: 0 0 56px;
		padding: 32px;
		background: var(--paper-2);
		border-left: 3px solid var(--orange-deep);
		border-radius: 0 4px 4px 0;
	}
	.cut .eyebrow {
		margin-bottom: 16px;
	}
	.cut-grid {
		display: grid;
		/* auto-fit: 3 columns when room (positives + negatives + questions),
		   2 when only two sections have content, 1 on narrow viewports.
		   minmax floor of 200px keeps prose legible at every breakpoint. */
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 28px;
	}
	@media (max-width: 760px) {
		.cut-grid {
			grid-template-columns: 1fr;
			gap: 22px;
		}
	}
	.cut-col h3 {
		margin: 0 0 12px;
		font-size: 17px;
		font-weight: 600;
		font-variation-settings: "SOFT" 50;
		color: var(--ink);
	}
	.cut-col--pos h3::before {
		content: "+ ";
		color: var(--orange-deep);
		font-family: var(--font-mono);
		font-weight: 600;
	}
	.cut-col--neg h3::before {
		content: "− ";
		color: var(--ink-3);
		font-family: var(--font-mono);
		font-weight: 600;
	}
	.cut-col--qa h3::before {
		content: "? ";
		color: var(--ember);
		font-family: var(--font-mono);
		font-weight: 600;
	}
	.cut-col ol {
		margin: 0;
		padding: 0 0 0 18px;
		font-size: 14px;
		line-height: 1.55;
		color: var(--ink-2);
	}
	.cut-col li {
		margin-bottom: 10px;
	}
	.cut-col strong {
		color: var(--ink);
		font-weight: 600;
	}
	.cut-link {
		color: inherit;
		text-decoration: none;
		border-bottom: 1px solid var(--rule-2);
		transition: border-color 0.15s var(--ease), color 0.15s var(--ease);
	}
	.cut-link:hover {
		color: var(--orange-deep);
		border-bottom-color: var(--orange-deep);
	}

	.briefing {
		margin: 0;
	}
	.empty {
		padding: 48px 0;
		color: var(--ink-3);
		border-top: 1px solid var(--rule);
		font-style: italic;
	}

	.item {
		display: grid;
		grid-template-columns: 56px 1fr;
		gap: 24px;
		padding: 32px 0;
		border-top: 1px solid var(--rule);
	}
	.item:last-of-type {
		border-bottom: 1px solid var(--rule);
	}
	.item--score-5 {
		background: linear-gradient(
			to right,
			var(--orange-pale) 0%,
			rgba(253, 233, 210, 0) 50%
		);
		margin: 0 -16px;
		padding-left: 16px;
		padding-right: 16px;
	}
	.item--score-5 .item-num {
		color: var(--ember);
	}

	.item-num {
		font-size: 28px;
		font-weight: 600;
		color: var(--ink-3);
		font-variant-numeric: tabular-nums;
		line-height: 1;
		padding-top: 6px;
		font-variation-settings: "SOFT" 50;
	}

	.item-meta {
		margin-bottom: 10px;
	}

	.item h2 {
		margin: 0 0 12px;
		font-size: var(--fs-h3);
		font-weight: 600;
		line-height: 1.3;
		letter-spacing: -0.01em;
		font-variation-settings: "SOFT" 50;
	}
	.item h2 a {
		text-decoration: none;
	}
	.item-summary {
		margin: 0 0 14px;
		font-size: 15.5px;
		color: var(--ink-2);
		line-height: 1.55;
	}
	.item-primitives {
		margin: 0;
		font-size: 14px;
		color: var(--ember);
	}
	.item-primitives .dot {
		color: var(--ink-3);
		margin: 0 4px;
	}

	/* Subscribe block */
	.subscribe-block {
		display: flex;
		gap: 32px;
		align-items: center;
		justify-content: space-between;
		margin-top: 64px;
		padding: 32px;
		background: var(--paper-2);
		border-radius: 4px;
		flex-wrap: wrap;
	}
	.subscribe-block h3 {
		font-weight: 600;
		font-size: var(--fs-h3);
		margin: 8px 0 6px;
	}
	.subscribe-block p {
		font-size: 15px;
		color: var(--ink-2);
		margin: 0;
		max-width: 460px;
	}
	.subscribe-button {
		display: inline-block;
		background: var(--ink);
		color: var(--paper) !important;
		text-decoration: none;
		padding: 12px 24px;
		border-radius: 4px;
		font-weight: 600;
		font-size: 15px;
		white-space: nowrap;
		flex-shrink: 0;
	}
	.subscribe-button:hover {
		background: var(--orange-deep);
	}

	/* Colophon */
	.how {
		margin-top: 80px;
		padding-top: 32px;
		border-top: 1px solid var(--rule);
		color: var(--ink-2);
	}
	.how h3 {
		font-size: var(--fs-h3);
		font-weight: 600;
		margin: 8px 0 16px;
		color: var(--ink);
	}
	.how p {
		max-width: 660px;
		font-size: 15px;
		line-height: 1.65;
	}
	.how-meta {
		margin-top: 16px;
		font-size: 14px;
		color: var(--ink-3);
	}
	.how-meta a {
		color: var(--orange-deep);
		text-decoration: none;
		font-weight: 600;
	}

	/* Right rail */
	.rail-section {
		margin-bottom: 28px;
	}
	.rail-section .eyebrow {
		margin-bottom: 8px;
	}
	.rail-stat-big {
		font-size: 28px;
		font-weight: 600;
		line-height: 1.1;
		letter-spacing: -0.02em;
		font-variation-settings: "SOFT" 50;
	}
	.rail-stat-med {
		font-size: 20px;
		font-weight: 600;
		font-variation-settings: "SOFT" 50;
	}
	.rail-meta {
		font-size: 12px;
		color: var(--ink-3);
		margin-top: 4px;
		font-family: var(--font-mono);
	}
	.rail-rule {
		border: 0;
		border-top: 1px solid var(--rule);
		margin: 24px 0;
	}
	.rail-dl {
		margin: 0;
		padding: 0;
	}
	.rail-dl div {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 6px 0;
		border-bottom: 1px dotted var(--rule);
	}
	.rail-dl div:last-child {
		border-bottom: 0;
	}
	.rail-dl dt {
		font-size: 13px;
		color: var(--ink-3);
		margin: 0;
	}
	.rail-dl dd {
		font-size: 18px;
		font-weight: 600;
		font-variant-numeric: tabular-nums;
		margin: 0;
		color: var(--ink);
	}
	.rail-primitives {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.rail-primitives li {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 6px 0;
		border-bottom: 1px dotted var(--rule);
	}
	.rail-primitives li:last-child {
		border-bottom: 0;
	}
	.rail-count {
		font-size: 12px;
		color: var(--ink-3);
		font-variant-numeric: tabular-nums;
	}
	.rail-text {
		font-size: 13px;
		color: var(--ink-2);
		line-height: 1.55;
		margin: 0;
	}
	.rail-link {
		display: inline-block;
		margin-top: 6px;
		color: var(--orange-deep);
		text-decoration: none;
		font-weight: 600;
	}
	.rail-link-inline {
		color: var(--orange-deep);
		text-decoration: none;
		font-weight: 600;
		white-space: nowrap;
	}
	.rail-text strong {
		color: var(--ink);
		font-weight: 600;
	}
</style>
