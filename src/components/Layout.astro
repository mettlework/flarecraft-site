---
interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		<meta property="og:title" content={title} />
		{description && <meta property="og:description" content={description} />}
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Inter:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<nav class="topnav">
			<a href="/" class="brand">FlareCraft</a>
			<div class="topnav-links">
				<a href="/archive/">Archive</a>
				<a href="/about/">About</a>
			</div>
		</nav>

		<main>
			<slot />
		</main>

		<style is:global>
			:root {
				--bg: #faf8f5;
				--bg-soft: #f3eee7;
				--fg: #1a1a1a;
				--fg-soft: #4a4a4a;
				--muted: #6b6b6b;
				--border: #e5e1db;
				--accent: #f6821f;
				--accent-soft: #fef1e4;
				--max: 880px;
				--font-serif: "Fraunces", Georgia, serif;
				--font-sans:
					"Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
					"Segoe UI", sans-serif;
			}

			* {
				box-sizing: border-box;
			}

			html,
			body {
				margin: 0;
				padding: 0;
				background: var(--bg);
				color: var(--fg);
				font-family: var(--font-sans);
				line-height: 1.55;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			a {
				color: inherit;
				text-decoration-thickness: 1px;
				text-underline-offset: 3px;
			}
			a:hover {
				color: var(--accent);
			}

			.topnav {
				display: flex;
				align-items: center;
				justify-content: space-between;
				max-width: var(--max);
				margin: 0 auto;
				padding: 24px 32px;
				border-bottom: 1px solid var(--border);
			}
			.brand {
				font-family: var(--font-serif);
				font-weight: 700;
				font-size: 20px;
				letter-spacing: -0.01em;
				text-decoration: none;
			}
			.brand:hover {
				color: var(--accent);
			}
			.topnav-links {
				display: flex;
				gap: 24px;
				font-size: 14px;
				color: var(--muted);
			}
			.topnav-links a {
				text-decoration: none;
			}

			main {
				max-width: var(--max);
				margin: 0 auto;
				padding: 64px 32px 96px;
			}

			.hero {
				margin-bottom: 64px;
			}
			.eyebrow {
				margin: 0 0 28px;
				font-size: 12px;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--accent);
				font-weight: 600;
			}
			h1 {
				font-family: var(--font-serif);
				font-weight: 700;
				font-size: clamp(36px, 6vw, 64px);
				line-height: 1.05;
				letter-spacing: -0.025em;
				margin: 0 0 28px;
			}
			.lede {
				font-size: 19px;
				color: var(--fg-soft);
				max-width: 640px;
				margin: 0 0 40px;
			}

			.stats {
				display: flex;
				gap: 48px;
				margin: 0 0 32px;
				padding: 24px 0;
				border-top: 1px solid var(--border);
				border-bottom: 1px solid var(--border);
			}
			.stats div {
				margin: 0;
			}
			.stats dt {
				font-size: 11px;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--muted);
				margin: 0 0 4px;
				font-weight: 600;
			}
			.stats dd {
				font-family: var(--font-serif);
				font-size: 32px;
				font-weight: 600;
				margin: 0;
				font-variant-numeric: tabular-nums;
				letter-spacing: -0.02em;
			}

			.primitive-row {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 8px;
				font-size: 13px;
			}
			.primitive-row-label {
				color: var(--muted);
				margin-right: 4px;
			}
			.primitive-tag {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				background: var(--bg-soft);
				padding: 4px 10px;
				border-radius: 999px;
				font-weight: 500;
			}
			.primitive-count {
				color: var(--accent);
				font-weight: 600;
				font-variant-numeric: tabular-nums;
			}

			.briefing {
				margin: 0;
			}
			.empty {
				padding: 48px 0;
				color: var(--muted);
				border-top: 1px solid var(--border);
			}

			.item {
				border-top: 1px solid var(--border);
				padding: 32px 0;
			}
			.item:last-child {
				border-bottom: 1px solid var(--border);
			}
			.item--score-5 {
				background: linear-gradient(
					to right,
					var(--accent-soft) 0%,
					transparent 40%
				);
				margin: 0 -16px;
				padding-left: 16px;
				padding-right: 16px;
			}
			.item-meta {
				display: flex;
				align-items: center;
				gap: 16px;
				font-size: 12px;
				color: var(--muted);
				margin-bottom: 12px;
				flex-wrap: wrap;
			}
			.item-num {
				font-family: var(--font-serif);
				font-variant-numeric: tabular-nums;
				font-weight: 600;
				color: var(--fg);
				font-size: 14px;
			}
			.item-score {
				color: var(--accent);
				letter-spacing: 1px;
			}
			.item-angle {
				font-size: 11px;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				font-weight: 600;
				background: var(--bg-soft);
				padding: 3px 8px;
				border-radius: 4px;
			}
			.item-source {
				font-style: italic;
			}

			.item h2 {
				font-family: var(--font-serif);
				font-weight: 600;
				font-size: 24px;
				line-height: 1.25;
				letter-spacing: -0.015em;
				margin: 0 0 12px;
			}
			.item h2 a {
				text-decoration: none;
			}
			.item h2 a:hover {
				color: var(--accent);
			}
			.item-summary {
				font-size: 16px;
				color: var(--fg-soft);
				margin: 0 0 16px;
				max-width: 640px;
			}
			.item-primitives {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-wrap: wrap;
				gap: 6px;
			}
			.item-primitives li {
				font-size: 12px;
				color: var(--accent);
				background: var(--accent-soft);
				padding: 3px 8px;
				border-radius: 4px;
				font-weight: 600;
			}

			.how {
				margin-top: 96px;
				padding-top: 48px;
				border-top: 1px solid var(--border);
				color: var(--fg-soft);
				font-size: 15px;
			}
			.how h3 {
				font-family: var(--font-serif);
				font-size: 20px;
				font-weight: 600;
				margin: 0 0 16px;
				color: var(--fg);
			}
			.how p {
				max-width: 720px;
			}
			.how strong {
				color: var(--fg);
				font-weight: 600;
			}
			.how-meta {
				margin-top: 24px;
				font-size: 14px;
				color: var(--muted);
			}
			.how-meta a {
				color: var(--accent);
				text-decoration: none;
			}
		</style>
	</body>
</html>
